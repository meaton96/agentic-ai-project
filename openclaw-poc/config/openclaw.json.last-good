{
  "gateway": {
    "mode": "local",
    "bind": "lan"
  },
  "tools": {
    "deny": [
      "gateway",
      "sessions_spawn",
      "subagents"
    ]
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/workspace",
      "model": {
        "primary": "vllm/cogito:70b"
      }
    }
